{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://content-engine.dev/schemas/packet.schema.json",
  "title": "Packet Manifest Schema",
  "description": "Schema validation for packet.yaml, the single source of truth for a content packet.",
  "$comment": "Defines the invariant contract enforced by scripts/validate-packet.sh for all packet.yaml files.",
  "type": "object",
  "required": [
    "packet_id",
    "title",
    "date",
    "topic",
    "lifecycle_status",
    "taxonomy",
    "lineage",
    "governance",
    "channels_manifest"
  ],
  "additionalProperties": false,
  "properties": {
    "packet_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$",
      "description": "Unique folder identifier matching YYYY-MM-DD-topic-slug."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable title of the content event."
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Primary date of the content event in YYYY-MM-DD format."
    },
    "topic": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Short topic slug."
    },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "idea",
        "briefing",
        "drafting",
        "review",
        "ready",
        "distributing",
        "published",
        "evergreen",
        "archived"
      ],
      "description": "Current lifecycle status of the content packet."
    },
    "taxonomy": {
      "type": "object",
      "required": ["pillars", "tags", "campaign", "series"],
      "additionalProperties": false,
      "properties": {
        "pillars": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Strategic content pillars."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fine-grained discovery tags."
        },
        "campaign": {
          "type": "string",
          "description": "Parent marketing campaign identifier."
        },
        "series": {
          "type": "string",
          "description": "Named recurring series identifier."
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "canonical_source": {
          "type": "string",
          "description": "External reference or paper URL if applicable."
        },
        "repurposed_from": {
          "type": ["array", "string"],
          "items": { "type": "string" },
          "description": "Parent packet_ids if derived from existing packets."
        },
        "related_project": {
          "type": "string",
          "description": "External issue or project key."
        },
        "derivatives": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Child packet_ids spawned from this packet."
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "type": "string",
          "description": "ISO-8601 timestamp of packet creation."
        },
        "updated_at": {
          "type": "string",
          "description": "ISO-8601 timestamp of last update."
        },
        "author": {
          "type": "string",
          "description": "Creator or author handle."
        },
        "owner": {
          "type": "string",
          "description": "Creator or owner handle."
        },
        "reviewers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Assigned code or content reviewers."
        },
        "related_project": {
          "type": "string",
          "description": "External issue or project key."
        }
      }
    },
    "channels_manifest": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^channels/[a-zA-Z0-9_-]+\\.md$"
      },
      "description": "List of active channel markdown files inside the channels/ folder."
    },
    "aggregate_metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_impressions": { "type": "integer", "minimum": 0 },
        "total_engagements": { "type": "integer", "minimum": 0 },
        "last_updated": { "type": "string" }
      }
    }
  }
}
