{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://content-engine.dev/schemas/metrics.schema.json",
  "title": "Performance Metrics Snapshot Schema",
  "description": "Standardized schema for post-publish quantitative performance metrics.",
  "type": "object",
  "required": [
    "packet_id",
    "channel_id",
    "platform",
    "measured_at",
    "metrics"
  ],
  "additionalProperties": false,
  "properties": {
    "packet_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$"
    },
    "channel_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "platform": {
      "type": "string",
      "enum": ["linkedin", "x", "facebook", "blog", "newsletter"]
    },
    "measured_at": {
      "type": "string",
      "description": "ISO-8601 timestamp when snapshot was collected."
    },
    "metrics": {
      "type": "object",
      "required": [
        "impressions",
        "engagements",
        "likes",
        "comments",
        "shares"
      ],
      "additionalProperties": false,
      "properties": {
        "impressions": { "type": "integer", "minimum": 0 },
        "engagements": { "type": "integer", "minimum": 0 },
        "likes": { "type": "integer", "minimum": 0 },
        "comments": { "type": "integer", "minimum": 0 },
        "shares": { "type": "integer", "minimum": 0 },
        "clicks": { "type": "integer", "minimum": 0 },
        "conversions": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
